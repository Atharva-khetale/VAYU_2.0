# VAYU X Environment Configuration
# Copy this to .env and modify as needed
# This file is NOT required - all settings have sensible defaults

# ============================================================================
# DEPLOYMENT CONFIGURATION
# ============================================================================

# Deployment mode: museum, home, security, warehouse
DEPLOYMENT_MODE=museum

# Environment: development, staging, production
ENVIRONMENT=development

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ============================================================================
# ROBOT IDENTIFICATION
# ============================================================================

# Unique robot identifier
ROBOT_ID=vayu_001

# Robot location/description
ROBOT_LOCATION=museum_entrance

# ============================================================================
# NETWORK CONFIGURATION
# ============================================================================

# WiFi Settings (for ESP32)
WIFI_SSID=VAYU_NETWORK
WIFI_PASSWORD=secure_password_here

# MQTT Broker (for robot-to-robot communication)
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USERNAME=vayu_user
MQTT_PASSWORD=vayu_password

# ============================================================================
# WEB DASHBOARD (OPTIONAL)
# ============================================================================

# Dashboard port
DASHBOARD_PORT=5000

# ============================================================================
# CLOUD INTEGRATION (OPTIONAL - NOT REQUIRED)
# ============================================================================

# Firebase (optional for digital twin backup)
FIREBASE_ENABLED=false
FIREBASE_PROJECT_ID=your-firebase-project
FIREBASE_API_KEY=your-firebase-key

# AWS IoT Core (optional alternative to Firebase)
AWS_IOT_ENABLED=false
AWS_IOT_ENDPOINT=your-aws-endpoint.iot.region.amazonaws.com
AWS_IOT_CERT_PATH=/path/to/cert.pem

# ============================================================================
# HARDWARE CONFIGURATION (FOR ESP32)
# ============================================================================

# These are configured in config.py but can be overridden

# Motor control pins
MOTOR_LEFT_PWM=5
MOTOR_RIGHT_PWM=8

# Servo pins
SERVO_HORIZONTAL_PIN=2
SERVO_VERTICAL_PIN=3

# Sensor pins
I2C_SDA=4
I2C_SCL=3

# ============================================================================
# SAFETY THRESHOLDS
# ============================================================================

# Battery (in volts)
BATTERY_MIN_VOLTAGE=10.0
BATTERY_CRITICAL_VOLTAGE=8.0

# Temperature (in celsius)
THERMAL_WARNING_CELSIUS=70
THERMAL_CRITICAL_CELSIUS=85

# Motion (safety limits)
MAX_LINEAR_VELOCITY=0.5      # m/s
MAX_ANGULAR_VELOCITY=180     # degrees/s
MAX_ACCELERATION=0.2         # m/s²

# ============================================================================
# PERFORMANCE TUNING
# ============================================================================

# Agent processing intervals (milliseconds)
SENSOR_POLL_INTERVAL_MS=50
DECISION_INTERVAL_MS=100
TELEMETRY_INTERVAL_S=5
HEARTBEAT_INTERVAL_S=10

# Thread pool configuration
MAX_THREADS=4
THREAD_POOL_SIZE=2

# Memory and queue limits
MAX_BUFFER_SIZE_MB=20
QUEUE_MAX_SIZE=100

# ============================================================================
# DEVELOPMENT / TESTING
# ============================================================================

# Enable detailed debug output
DEBUG_MODE=true

# Enable test fixtures/mocks
USE_MOCK_HARDWARE=true

# Run test suite before startup
RUN_TEST_SUITE_ON_STARTUP=false

# ============================================================================
# NOTES
# ============================================================================

# 1. This file is optional - remove it and system uses defaults in config.py
# 2. All values have sensible defaults - only override what you need
# 3. Never commit secrets (passwords) to version control
# 4. Use environment variables in production instead of .env files
# 5. For hardware deployment, set ENVIRONMENT=production
# 6. Cloud services are optional - edge-first architecture works without them

# ============================================================================
# QUICK DEPLOYMENT PROFILES
# ============================================================================

# MUSEUM MODE (Exhibition tours)
# DEPLOYMENT_MODE=museum
# ROBOT_LOCATION=main_hall
# LOG_LEVEL=INFO

# HOME MODE (Elderly assistance)
# DEPLOYMENT_MODE=home
# ROBOT_LOCATION=living_room
# LOG_LEVEL=INFO

# SECURITY MODE (Surveillance)
# DEPLOYMENT_MODE=security
# ROBOT_LOCATION=hallway
# LOG_LEVEL=WARNING

# WAREHOUSE MODE (Inventory)
# DEPLOYMENT_MODE=warehouse
# ROBOT_LOCATION=storage_area
# LOG_LEVEL=INFO

# ============================================================================
# TROUBLESHOOTING
# ============================================================================

# If you see "Configuration validation failed":
#   - Check BATTERY thresholds: CRITICAL < MIN
#   - Check THERMAL thresholds: WARNING < CRITICAL
#   - Check DEPLOYMENT_MODE is valid

# If agents fail to start:
#   - Set LOG_LEVEL=DEBUG for detailed output
#   - Check config.py for agent-specific settings
#   - Run: python test_suite.py to validate

# If dashboard won't load:
#   - Verify DASHBOARD_PORT is not in use
#   - Check Flask is installed: pip install Flask
#   - Try different port: DASHBOARD_PORT=8080

# ============================================================================
# HELPFUL COMMANDS
# ============================================================================

# Start with custom deployment mode:
# DEPLOYMENT_MODE=security python main.py

# Start with debugging:
# LOG_LEVEL=DEBUG python main.py --interactive

# Run test suite first:
# python test_suite.py

# Monitor system in real-time:
# tail -f logs/vayu_001.log

# Check system health via API:
# curl http://localhost:5000/health | jq

# List all agents:
# curl http://localhost:5000/agents | jq
